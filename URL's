// Modules
module "app_gateway" {
  source  = "app.terraform.io/AIZ/appgw-cep/azurerm"
  version = "3.0.0"
  count   = var.app_env == "prod" ? 1 : 0


  appgw = {
    name      = format("%s-%s-dr", var.app_name, var.app_env)
    subnet_id = data.azurerm_subnet.failover_web_ingress_subnet[0].id
    // Get Webingress ip , worst case pick an ip from the range 
    private_ip   = cidrhost(data.azurerm_subnet.failover_web_ingress_subnet[0].address_prefixes[0], 4)
    sku_capacity = 2
  }
  autoscale_max_capacity = 4
  autoscale_min_capacity = 1
  backend_address_pools = [
    {
      name         = format("%s-ui-%s", var.app_name, var.app_env)
      ip_addresses = null
      fqdns = [
        "app-gears-angular-prod-dr.ase-epggears-prod-dr.appserviceenvironment.net"
      ]
    }
  ]
  backend_http_listeners = local.http_listeners
  backend_http_settings = [
    {
      name                         = "ui-settings"
      pick_host_name_from_backend  = true
      host_name                    = null
      enable_cookie_based_affinity = false
      affinity_cookie_name         = null
      path                         = null
      port                         = 443
      request_timeout              = 400
      probe_settings = {
        match_body          = null
        path                = "/"
        unhealthy_threshold = 3
        timeout             = 5
        interval            = 10
        status_code         = [200]
      }
    }
  ]
  certificates = [
    {
      cert_name           = var.cert_name
      key_vault_secret_id = var.primary_keyvault_certificate.secret_id
    },

    {
      cert_name           = var.cert_name_cnh
      key_vault_secret_id = var.app_env == "prod" ? ("https://kv-gears-prod-d123zxf2.vault.azure.net/secrets/gearsDOTcnhDOTcom-PFX/f624f24eb3bc4c50880c886ecb9dde02") : var.primary_keyvault_certificate_cnh.secret_id
    }

  ]
  #diagnostics_retention_days = 30
  enable_autoscale = "true"
  #identity_id      = var.primary_gateway_mi.mi_id
  identity_id = module.gateway_mi.mi_id
  is_public   = "true"
  location    = var.dr_location
  # log_analytics_workspace_id = var.SENTINEL_LA_ID
  rg_name = var.rg_name
  # default_tags               = local.default_tags
  tags = var.default_tags


}

